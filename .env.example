# Database Configuration
# Get your connection string from NeonDB or your PostgreSQL provider
# For production (Render/NeonDB), ensure sslmode=require is included
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# Admin Configuration
# Change these to your own secure credentials before deploying!
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_password
ADMIN_NAME=Administrator

# Session Configuration
# IMPORTANT: Change this to a random secret string in production!
# Use: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_secret_key_here_change_in_production

# Server Configuration
PORT=3000

# Environment
# Set to 'production' in production deployments
NODE_ENV=development
